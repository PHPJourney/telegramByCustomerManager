# Telegram API 配置
# 从 https://my.telegram.org/apps 获取
# 开发阶段可以使用测试凭证：
# API ID: 17349
# API Hash: 344583e45741c457fe1862106095a5eb
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Telegram Bot Token (用于接收客户消息)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# JWT Secret
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_change_in_production

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/telegram_cs?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Server
PORT=3000
NODE_ENV=development

# CORS
CLIENT_URL=http://localhost:5173
