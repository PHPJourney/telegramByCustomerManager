# ==========================================
# 数据库配置
# ==========================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/telegram_cs?schema=public"

# ==========================================
# Redis 配置
# ==========================================
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# ==========================================
# JWT 认证配置
# ==========================================
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_REFRESH_EXPIRES_IN="30d"

# ==========================================
# Telegram Bot API 配置
# ==========================================
TELEGRAM_BOT_TOKEN="your-bot-token-from-botfather"
TELEGRAM_WEBHOOK_URL="https://your-domain.com/api/webhook/telegram"
TELEGRAM_WEBHOOK_SECRET="your-webhook-secret"

# ==========================================
# Telegram Client API (MTProto) 配置
# ==========================================
TELEGRAM_API_ID="your-api-id-from-my.telegram.org"
TELEGRAM_API_HASH="your-api-hash-from-my.telegram.org"
TELEGRAM_SESSION_PATH="./sessions"

# ==========================================
# Telegram 代理服务器配置
# ==========================================
TELEGRAM_PROXY_ENABLED="true"
TELEGRAM_PROXY_HOST="your-proxy-server-ip"
TELEGRAM_PROXY_PORT="1080"
TELEGRAM_PROXY_USERNAME=""
TELEGRAM_PROXY_PASSWORD=""

# ==========================================
# AI 服务配置（东京服务器）
# ==========================================
AI_SERVICE_URL="http://tokyo-server-ip:8080/api/v1"
AI_API_KEY="your-ai-api-key"
AI_TIMEOUT=30000
AI_MAX_RETRIES=3

# ==========================================
# Web3 配置
# ==========================================
SUPPORTED_CHAINS="ethereum,bsc,polygon,arbitrum"
ALCHEMY_API_KEY="your-alchemy-api-key"
INFURA_API_KEY="your-infura-api-key"

# ==========================================
# 服务器配置
# ==========================================
PORT=3000
NODE_ENV="development"
CLIENT_URL="http://localhost:5173"
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# ==========================================
# WebSocket 配置
# ==========================================
WS_PORT=3001
WS_CORS_ORIGINS="http://localhost:5173"

# ==========================================
# 文件上传配置
# ==========================================
MAX_FILE_SIZE=10485760  # 10MB
UPLOAD_DIR="./uploads"
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/gif,application/pdf,text/plain"

# ==========================================
# 日志配置
# ==========================================
LOG_LEVEL="info"
LOG_FILE="./logs/app.log"

# ==========================================
# 速率限制配置
# ==========================================
RATE_LIMIT_WINDOW_MS=900000  # 15分钟
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# 客服系统配置
# ==========================================
MAX_CONCURRENT_CHATS_PER_AGENT=10
MESSAGE_QUEUE_NAME="customer-messages"
ASSIGNMENT_STRATEGY="round-robin"  # round-robin, least-connections, random

# ==========================================
# 邮件配置（可选）
# ==========================================
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your-email@example.com"
SMTP_PASS="your-email-password"
